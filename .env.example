# Bron's Beach Rentals — env vars
#
# For staging: use Stripe TEST keys (start with sk_test_ / pk_test_)
# For production (post-deal-close): swap to live keys + set the
# Bron's connected account ID below.

# Stripe — required for checkout to work
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Connect — when Bron onboards via Connect, paste his connected
# account ID here. While empty, checkout runs without Connect (charges
# land in the platform account, split is metadata-only).
STRIPE_BRONS_CONNECTED_ACCT_ID=

# App URL — used for Stripe success/cancel redirects
NEXT_PUBLIC_APP_URL=https://bronsbeach.com
